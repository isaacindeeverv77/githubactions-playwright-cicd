pipeline {
    agent any
    
    triggers {
        // Poll SCM every 5 minutes for changes
        pollSCM('H/5 * * * *')
        
        // Alternative: Check every 15 minutes
        // pollSCM('H/15 * * * *')
        
        // Alternative: Check every hour
        // pollSCM('H * * * *')
    }
    
    parameters {
        choice(
            name: 'BROWSER',
            choices: ['all', 'chromium', 'firefox', 'webkit', 'mobile-chrome', 'mobile-safari'],
            description: 'Select browser to run tests on'
        )
        choice(
            name: 'TEST_SUITE',
            choices: ['all', 'booking', 'login', 'checkout', 'responsive-login'],
            description: 'Select test suite to run'
        )
        booleanParam(
            name: 'HEADED_MODE',
            defaultValue: false,
            description: 'Run tests in headed mode (with browser UI visible)'
        )
        booleanParam(
            name: 'DEBUG_MODE',
            defaultValue: false,
            description: 'Run tests in debug mode'
        )
        string(
            name: 'WORKERS',
            defaultValue: '',
            description: 'Number of parallel workers (leave empty for default)'
        )
        string(
            name: 'RETRIES',
            defaultValue: '',
            description: 'Number of retries for failed tests (leave empty for default)'
        )
        booleanParam(
            name: 'UPDATE_SNAPSHOTS',
            defaultValue: false,
            description: 'Update snapshots during test run'
        )
        string(
            name: 'GREP',
            defaultValue: '',
            description: 'Run tests matching this grep pattern (e.g., "@smoke")'
        )
    }
    
    tools {
        nodejs 'NodeJS' // Configure NodeJS installation in Jenkins Global Tool Configuration
    }
    
    environment {
        CI = 'true'
        HOME = "${WORKSPACE}"
        PLAYWRIGHT_BROWSERS_PATH = "${WORKSPACE}/ms-playwright"
    }
    
    stages {
        stage('Checkout') {
            steps {
                echo 'Checking out code...'
                checkout scm
            }
        }
        
        stage('Install Dependencies') {
            steps {
                echo 'Installing Node.js dependencies...'
                sh 'npm ci'
            }
        }
        
        stage('Install Playwright Browsers') {
            steps {
                script {
                    def browsers = params.BROWSER == 'all' ? 'chromium firefox webkit' : params.BROWSER.replaceAll('mobile-', '')
                    echo "Installing Playwright browsers: ${browsers}..."
                    sh "npx playwright install --with-deps ${browsers}"
                }
            }
        }
        
        stage('Run Playwright Tests') {
            steps {
                script {
                    def testCommand = 'npx playwright test'
                    
                    // Add browser selection
                    if (params.BROWSER != 'all') {
                        testCommand += " --project=${params.BROWSER}"
                    }
                    
                    // Add test suite selection
                    if (params.TEST_SUITE != 'all') {
                        testCommand += " ${params.TEST_SUITE}.spec.ts"
                    }
                    
                    // Add headed mode
                    if (params.HEADED_MODE) {
                        testCommand += ' --headed'
                    }
                    
                    // Add debug mode
                    if (params.DEBUG_MODE) {
                        testCommand += ' --debug'
                    }
                    
                    // Add workers
                    if (params.WORKERS != '') {
                        testCommand += " --workers=${params.WORKERS}"
                    }
                    
                    // Add retries
                    if (params.RETRIES != '') {
                        testCommand += " --retries=${params.RETRIES}"
                    }
                    
                    // Add update snapshots
                    if (params.UPDATE_SNAPSHOTS) {
                        testCommand += ' --update-snapshots'
                    }
                    
                    // Add grep pattern
                    if (params.GREP != '') {
                        testCommand += " --grep='${params.GREP}'"
                    }
                    
                    echo "Running command: ${testCommand}"
                    sh testCommand
                }
            }
        }
    }
    
    post {
        always {
            echo 'Publishing test results...'
            
            // Publish JUnit test results
            junit testResults: 'test-results/results.xml', allowEmptyResults: true
            
            // Archive test artifacts
            archiveArtifacts artifacts: 'test-results/**/*', allowEmptyArchive: true
            archiveArtifacts artifacts: 'playwright-report/**/*', allowEmptyArchive: true
            
            // Publish HTML report
            publishHTML([
                allowMissing: false,
                alwaysLinkToLastBuild: true,
                keepAll: true,
                reportDir: 'playwright-report',
                reportFiles: 'index.html',
                reportName: 'Playwright Test Report',
                reportTitles: 'Playwright Test Report'
            ])
        }
        
        success {
            echo 'Tests passed successfully!'
        }
        
        failure {
            echo 'Tests failed. Check the Playwright Test Report for details.'
        }
        
        cleanup {
            echo 'Cleaning up workspace...'
            cleanWs()
        }
    }
}